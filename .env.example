# CDSV UI — copy to .env.local (not committed)
VITE_API_BASE_URL=/api/v1
# Set to "false" to use real HTTP via apiRequest (backend must be available)
VITE_USE_MOCK_API=true
VITE_APP_NAME=CDSV Security Platform

# Simulated SOC API (used when VITE_USE_MOCK_API=true)
# Fraction of requests that throw 502–504 (resilience drills)
VITE_SOC_API_FAILURE_RATE=0.07
VITE_SOC_API_MIN_LATENCY_MS=120
VITE_SOC_API_MAX_LATENCY_MS=520
